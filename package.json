{
  "name": "haft-website",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:site": "concurrently -k -n api,vite -c blue,green \"node server.js\" \"vite\"",
    "build": "vite build && node scripts/copy-contact-form-to-dist.mjs",
    "preview": "vite preview",
    "preview:site": "concurrently -k -n api,preview -c blue,green \"node server.js\" \"vite preview\"",
    "serve": "node server.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "resend": "^6.9.4"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "vite": "^6.2.0"
  }
}
