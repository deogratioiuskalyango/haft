# Copy to `.env` for local dev, or set the same names in your host’s environment UI for production.
# This file is safe to commit (dummy names only).

# ---------------------------------------------------------------------------
# Server-only (scripts, CI, future API routes)
# These are NOT exposed by Vite unless you read them in vite.config.js and inject them.
# ---------------------------------------------------------------------------
# DATABASE_URL=postgresql://user:pass@localhost:5432/dbname
# API_SECRET_KEY=replace-with-secret

# ---------------------------------------------------------------------------
# Vite — client-side (browser)
# Only variables prefixed with VITE_ are exposed to front-end code via import.meta.env.
# Treat every VITE_* value as PUBLIC (anyone can read it in the built JS).
# Use for publishable keys / public endpoints only — never for real secrets.
# ---------------------------------------------------------------------------
# VITE_PUBLIC_API_URL=https://api.example.com
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# ---------------------------------------------------------------------------
# If you later use Next.js
# NEXT_PUBLIC_* is injected into the browser the same way — public config only, not secrets.
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_URL=https://www.example.org

# ---------------------------------------------------------------------------
# YouTube channel page (server.js proxy)
# Prefer YOUTUBE_API_KEY for public channel data (simplest).
# Or use OAuth (same GCP project as below) + GOOGLE_OAUTH_REFRESH_TOKEN.
# ---------------------------------------------------------------------------
# YOUTUBE_API_KEY=your-youtube-data-api-key
# YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxxxx
# Or use a handle (with or without @) instead of channel ID:
# YOUTUBE_CHANNEL_HANDLE=@YourChannelHandle
# YOUTUBE_MAX_RESULTS=12
# YOUTUBE_CACHE_SECONDS=120
# PORT=3000

# ---------------------------------------------------------------------------
# Pesapal (donation checkout — same OAuth flow as Pesapal PHP iframe sample)
# Register callback + IPN URLs in your Pesapal merchant dashboard.
# ---------------------------------------------------------------------------
# PESAPAL_CONSUMER_KEY=your_consumer_key
# PESAPAL_CONSUMER_SECRET=your_consumer_secret
# Full URL where shoppers return after payment (must match dashboard / be allowed)
# PESAPAL_CALLBACK_URL=https://your-domain.com/pages/donation.html?pesapal=1
# IPN URL to register: https://your-domain.com/api/pesapal/ipn
# Sandbox (default): demo.pesapal.com — set false for live
# PESAPAL_SANDBOX=true
# Optional overrides (defaults follow sandbox vs live)
# PESAPAL_ORDER_API=http://demo.pesapal.com/api/PostPesapalDirectOrderV4
# PESAPAL_QUERY_API=http://demo.pesapal.com/api/querypaymentstatus

# ---------------------------------------------------------------------------
# Google OAuth (Web client JSON — keep only in .env, never commit)
# Used when YOUTUBE_API_KEY is not set; requires GOOGLE_OAUTH_REFRESH_TOKEN.
# ---------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
# GOOGLE_PROJECT_ID=your-gcp-project-id
# GOOGLE_OAUTH_REFRESH_TOKEN=1//xxxxx
